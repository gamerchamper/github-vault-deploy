# GitHub Vault — copy to .env in this directory and fill in values

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=
APP_URL=http://localhost:3000
PORT=3000

# Optional: link Bitbucket Cloud accounts for additional storage
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Optional: link Codeberg accounts (Forgejo API — OAuth app under Settings → Applications)
CODEBERG_CLIENT_ID=
CODEBERG_CLIENT_SECRET=
# CODEBERG_BASE_URL=https://codeberg.org
# CODEBERG_RATE_LIMIT_MINUTE=60
# CODEBERG_RATE_LIMIT_HOUR=3600
# CODEBERG_MAX_BLOB_MB=95

# Optional: link Pastebin member accounts (developer key from pastebin.com/doc_api)
PASTEBIN_DEV_KEY=
# PASTEBIN_MAX_PASTE_KB=512
# PASTEBIN_PASTE_PRIVATE=1
# PASTEBIN_RATE_LIMIT_HOUR=3000
