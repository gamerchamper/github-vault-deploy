# GitHub Vault — copy to .env in this directory and fill in values

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=
APP_URL=http://localhost:3000
PORT=3000

# Optional: link Bitbucket Cloud accounts for additional storage
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
# Register callback in Bitbucket OAuth consumer: {APP_URL}/auth/bitbucket/callback
