# Vault Sync CLI configuration
# Copy to .env in the folder where you run: npm run start:cli

VAULT_URL=https://your-vault-server.example.com
VAULT_API_KEY=gv_your_api_key_here

# Main local folder mirrored to vault root /
VAULT_SYNC_ROOT=/home/you/GitHub Vault

# Sync interval in seconds (default 30)
VAULT_SYNC_INTERVAL=30

# 1 or 0
VAULT_SYNC_ENABLED=1

# Convert uploaded videos (mp4, mkv, mov, etc.) to HLS on server — 1 or 0 (default 1)
VAULT_CONVERT_HLS=1

# Optional display name in Agents tab
VAULT_AGENT_NAME=my-linux-pc

# Optional: JSON array or comma-separated local paths
# VAULT_ADDITIONAL_FOLDERS=[{"localPath":"/home/you/Pictures","name":"Pictures"}]
# VAULT_ADDITIONAL_FOLDERS=/home/you/Pictures,/home/you/Documents

# Optional data directory (default ~/.vault-sync)
# VAULT_SYNC_DATA_DIR=/home/you/.vault-sync
