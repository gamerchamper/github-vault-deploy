{
  "name": "github-vault",
  "version": "1.0.0",
  "description": "Distributed file storage across multiple GitHub repositories",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run server",
    "server": "node scripts/run-server.js",
    "server:dev": "node --watch server/index.js",
    "client": "node scripts/run-client.js",
    "client:install": "npm --prefix clients/vault-upload install",
    "client:help": "node scripts/run-client.js --help",
    "client:desktop": "node scripts/run-client.js desktop",
    "client:ui": "node scripts/run-client.js ui",
    "client:dist": "npm --prefix clients/vault-upload run dist",
    "client:pack": "npm --prefix clients/vault-upload run pack",
    "client:test": "npm --prefix clients/vault-upload test",
    "dev": "npm run server:dev",
    "test": "mocha test/**/*.test.js --timeout 10000",
    "test:unit": "mocha test/services/**/*.test.js test/public/**/*.test.js --timeout 10000",
    "test:routes": "mocha test/routes/**/*.test.js --timeout 10000",
    "test:e2e": "playwright test",
    "migrate-to-mysql": "node scripts/migrate-to-mysql.js",
    "deploy:push": "node scripts/push-deploy-repo.js",
    "deploy:push:dry-run": "node scripts/push-deploy-repo.js --dry-run",
    "plex:sync": "node clients/plex-sync/sync.js"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "better-sqlite3": "^11.10.0",
    "connect-sqlite3": "^0.9.16",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^10.9.1",
    "mysql2": "^3.22.5",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "sharp": "^0.33.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  }
}
